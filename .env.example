# SAIVEX production environment template
# Copy this file to .env locally, then fill your real values.
# Never upload your real .env publicly.

OPENROUTER_API_KEY=your_openrouter_api_key_here
SECRET_KEY=change_this_to_a_long_random_secret_key
SAIVEX_PUBLIC_URL=http://127.0.0.1:5000

# SQLite default. Later we can replace this with PostgreSQL if needed.
DATABASE_URL=sqlite:///instance/saivex.db

# Flask / production
PRODUCTION=1
FLASK_DEBUG=0
PORT=5000
SESSION_COOKIE_SECURE=False
SAIVEX_MAX_UPLOAD_MB=100

# Optional OAuth / Firebase / payment keys if your app uses them
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FIREBASE_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
